# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Build and distribution artifacts
dist/
build/
*.egg-info/
.vite/
.cache/

# Frontend build artifacts
frontend/dist/
frontend/build/
frontend/.vite/

# Compressed archives
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.bz2
*.xz
*.7z
*.rar

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/
.venv/
venv/

# Environment files
.env
.env.local
.env.*
backend/.env
backend/.env.local
backend/.env.*
frontend/.env
frontend/.env.local
frontend/.env.*

# Keep example environment files
!.env.example
!backend/.env.example
!frontend/.env.example

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage reports
.coverage
coverage/
htmlcov/
frontend/coverage/
backend/coverage/

# IDE and editor files
# VS Code workspace recommendations/tasks are part of the developer experience.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
.idea/

# OS generated files
.DS_Store
Thumbs.db

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Python tooling cache
.ruff_cache/
.tox/
.nox/

# Runtime generated files
backend/tmp/*
backend/outputs/*
uploads/**/batch_*.json

# Keep folder placeholders
!backend/tmp/.gitkeep
!backend/outputs/.gitkeep