APP_ENV=development
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8891
TESTING=false

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

UPLOAD_DIR=backend/uploads
OUTPUT_DIR=backend/outputs
TEMP_DIR=backend/tmp
MAX_UPLOAD_SIZE_MB=2048
MAX_BATCH_FILES=20
MAX_VIDEO_DURATION_MINUTES=180

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage backend is explicit. Use "local" unless you intentionally enable S3.
# S3_BUCKET alone does not switch storage to S3.
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=

TRANSLATE_PROVIDER=openai
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TRANSLATE_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:12b
# Optional. If empty, tasks auto-select by video duration unless task options specify model_size.
WHISPER_MODEL=
HF_TOKEN=

FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
FFMPEG_PRESET=ultrafast
FFMPEG_TIMEOUT_SECONDS=1800
FFPROBE_TIMEOUT_SECONDS=60
REPORT_EXPORT_TIMEOUT_SECONDS=120

# Production guardrails
DEMO_MODE=true
# When true, non-health API routes require Authorization: Bearer <token> or X-API-Token.
REQUIRE_AUTH_TOKEN=false
AUTH_TOKEN=
TASK_CLEANUP_DAYS=7
# Requests per IP per hour. Set 0 to disable for local development.
RATE_LIMIT_PER_IP=0
S3_UPLOAD_REQUIRED=false
